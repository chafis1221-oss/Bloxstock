# Nomor WA tujuan kirim stock otomatis
# Format: kode negara + nomor (tanpa +), pisah koma jika lebih dari satu
# Contoh: 6281234567890@s.whatsapp.net
TARGET_NUMBERS=6281234567890@s.whatsapp.net,6289876543210@s.whatsapp.net

# Jadwal cron kirim otomatis (default setiap 4 jam)
# "0 */4 * * *" = jam 00:00, 04:00, 08:00, 12:00, 16:00, 20:00
CRON_SCHEDULE=0 */4 * * *
